# Провайдер: stub | openai | ollama | local
LLM_PROVIDER=stub

# Если LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Если LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Если LLM_PROVIDER=local (Hugging Face / Transformers)
TRANSFORMERS_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
DEVICE=cpu # cpu или cuda
